# Provider-agnostic LLM config (recommended)
# Supported provider values: auto, openrouter, openai, groq, custom
LLM_PROVIDER=auto
LLM_API_KEY=your_api_key_here
# Optional: when blank, provider-specific defaults are used.
LLM_MODEL=
# For custom OpenAI-compatible endpoints, set full chat completions URL.
# Examples:
# - OpenAI: https://api.openai.com/v1/chat/completions
# - Groq: https://api.groq.com/openai/v1/chat/completions
# - OpenRouter: https://openrouter.ai/api/v1/chat/completions
LLM_BASE_URL=
LLM_FALLBACK_MODELS=meta-llama/llama-3.1-8b-instruct:free,qwen/qwen-2.5-7b-instruct:free,deepseek/deepseek-chat:free
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2

# Backward-compatible legacy vars (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_URL=
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_TIMEOUT_SECONDS=
OPENROUTER_MAX_RETRIES=
QUERY_CACHE_SIZE=256
EARLY_STOP_CONFIDENCE=0.86
DETERMINISTIC_SEED=17
COVERAGE_WARNING_THRESHOLD=0.34
